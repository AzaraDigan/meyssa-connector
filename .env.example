# Meyssa connector environment variables.
#
# Copy this file to .env for LOCAL development only. NEVER commit a filled-in .env.
# In production these values live in Vercel Project Settings > Environment Variables.
# Azara pastes the real tokens into Vercel directly. They must never appear in chat,
# in this repo, or in any committed file.

# --- Secrets (paste into Vercel only) ---

# RecruitCRM REST API token.
# IMPORTANT: the key shared in chat on 2026-04-20 must be rotated before any use.
RECRUITCRM_API_TOKEN=

# Webflow Data API v2 token. Scope required: CMS read + write.
WEBFLOW_API_TOKEN=

# Optional shared secret. If set, /api/sync rejects any request that does not
# present it. Lets us trigger the endpoint from an external scheduler safely.
SYNC_SECRET=

# Optional cap on how many jobs a run fetches. Leave empty for all open jobs.
# Set to 3 for the first test sync. Can also be passed per-run as ?limit=3.
SYNC_MAX_JOBS=

# --- Non-secret config (safe to keep in the repo defaults, listed here for clarity) ---

# RecruitCRM API base URL. Confirm the exact host and version in session 2.
RECRUITCRM_API_BASE=https://api.recruitcrm.io/v1

# Webflow identifiers (public, not secret).
WEBFLOW_SITE_ID=698d64462e86f6fa77372348
WEBFLOW_OPPORTUNITIES_COLLECTION_ID=69e7715df59318dbed8e9b8c
